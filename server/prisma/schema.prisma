// Prisma schema for TaskFlow
// Database: PostgreSQL (hosted on Railway)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  project_lead
  quality_reviewer
  tasker
}

enum ProjectStatus {
  active
  completed
  on_hold
  cancelled
}

enum TaskStatus {
  backlog
  todo
  in_progress
  in_review
  done
}

enum Priority {
  low
  medium
  high
  urgent
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  avatar    String?
  role      Role     @default(tasker)
  jobTitle  String   @default("Team Member")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  projectMemberships ProjectMember[]
  assignedTasks      Task[]          @relation("TaskAssignee")
  createdTasks       Task[]          @relation("TaskCreator")
  createdProjects    Project[]       @relation("ProjectCreator")
  activities         Activity[]
  remarks            Remark[]        @relation("RemarkAuthor")

  @@map("users")
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String        @default("")
  status      ProjectStatus @default(active)
  progress    Int           @default(0)
  color       String        @default("#3b82f6")
  dueDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  creatorId String
  creator   User            @relation("ProjectCreator", fields: [creatorId], references: [id])
  members   ProjectMember[]
  tasks     Task[]
  activities Activity[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String     @default("")
  status      TaskStatus @default(todo)
  priority    Priority   @default(medium)
  dueDate     DateTime?
  tags        String[]   @default([])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  projectId  String
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creatorId  String
  creator    User    @relation("TaskCreator", fields: [creatorId], references: [id])
  remarks    Remark[]

  @@map("tasks")
}

model Activity {
  id        String   @id @default(cuid())
  action    String
  target    String
  type      String   // task | project | comment | member
  createdAt DateTime @default(now())

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("activities")
}

model Remark {
  id        String   @id @default(cuid())
  content   String
  type      String   @default("review") // review | feedback | issue
  createdAt DateTime @default(now())

  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("RemarkAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@map("remarks")
}
